		}

		// Show 160x600 side banners during page load if window is wide enough
		function ShowInitialSideBanners() {
			if (window.optiAds) return; // No 160x600 side banners in Opti Digital
			var w = window.innerWidth;
			var h = window.innerHeight;
			if (w < 1024 || h < 600) return;

			var leftDiv, rightDiv;
			if (window.ascAds) {
				leftDiv = ascGetOrCreateDiv(adPrefix+'_160x600');
				rightDiv = ascGetOrCreateDiv(adPrefix+'_160x600_2');
			} else {
				leftDiv = document.getElementById(adPrefix+'_160x600');
				rightDiv = document.getElementById(adPrefix+'_160x600_2');
			}

			if (leftDiv) {
				leftDiv.style.display = 'block';
				leftDiv.style.visibility = 'visible';
				leftDiv.style.width = '160px';
				leftDiv.style.left = '0px';
				leftDiv.style.top = '50%';
				leftDiv.style.transform = 'translateY(-50%)';
			}
			if (rightDiv) {
				rightDiv.style.display = 'block';
				rightDiv.style.visibility = 'visible';
				rightDiv.style.width = '160px';
				rightDiv.style.left = 'auto';
				rightDiv.style.right = '0px';
				rightDiv.style.top = '50%';
				rightDiv.style.transform = 'translateY(-50%)';
			}

			ShowAd1();
			console.log('ShowInitialSideBanners: ' + w + 'x' + h);
		}
		//window.addEventListener('load', ShowInitialSideBanners);

		var scrollerMessage = "   ONLINE GAME DESYNC GLITCH FIXED! WELCOME TO BASEBALL BROS! ROSTERS HAVE BEEN UPDATED FOR THE 2026 SEASON!";

		const element = document.getElementById('openfl-content');
		// Ensure 'element' is not null before adding event listeners if there's any chance it might not exist yet.
		// Function to keep the element focused
		function keepFocus() {
			element.focus();
		}
		// Event listeners to restore focus when lost
		element.addEventListener('blur', keepFocus);
		element.addEventListener('focusout', keepFocus);
	</script>
	<script>
		function trackSaveLifespan() {
			try {
				const NOW = Date.now();
				const MS_IN_DAY = 1000 * 60 * 60 * 24;
				
				let saveCreated = localStorage.getItem('bros_save_created_ts');
				let sessionCount = parseInt(localStorage.getItem('bros_local_session_count') || '0', 10);
				
				sessionCount++;
				localStorage.setItem('bros_local_session_count', sessionCount);

				let ageBucket = "";

				if (!saveCreated) {
					// No save found. Mark the creation time.
					localStorage.setItem('bros_save_created_ts', NOW);
					ageBucket = "0_Days (New or Wiped)";
				} else {
					// Save exists! Calculate age in days.
					let ageInDays = Math.floor((NOW - parseInt(saveCreated, 10)) / MS_IN_DAY);
					
					if (ageInDays === 0) ageBucket = "0_Days (Same Day Return)";
					else if (ageInDays === 1) ageBucket = "1_Day";
					else if (ageInDays >= 2 && ageInDays <= 3) ageBucket = "2_to_3_Days";
					else if (ageInDays >= 4 && ageInDays <= 7) ageBucket = "4_to_7_Days";
					else ageBucket = "8_Plus_Days";
				}

				// Fire custom GA4 Event
				gtag('event', 'Save_Persistence_Check', {
					'save_age_bucket': ageBucket,
					'local_session_count': sessionCount
				});
			} catch (e) {
				// Catches strict incognito modes where localStorage is fully blocked
				gtag('event', 'Save_Persistence_Check', {
					'save_age_bucket': 'Storage_Blocked'
				});
			}
		}
		trackSaveLifespan();
	</script>


