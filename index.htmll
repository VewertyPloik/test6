		<script>
			//                                                                                                                          var doFeedback = true;
			function getOSFromUserAgent() {
				const userAgent = navigator.userAgent;
				const platform = navigator.platform;

				// Check for common platforms and OS
				if (/Windows NT/i.test(userAgent)) return 'Windows';
				if (/Mac OS X/i.test(userAgent)) return 'macOS';
				if (/Linux/i.test(userAgent)) return 'Linux';
				if (/Android/i.test(userAgent)) return 'Android';
				if (/iPhone|iPad|iPod/i.test(userAgent)) return 'iOS';
				if (/CrOS/i.test(userAgent)) return 'Chrome OS';

				// Default to the platform if no match
				return platform || 'Unknown';
			}
			async function sendFeedback() {
				var feedback = '*'+document.getElementById("feedback").value.trim()+'*';
				var email = document.getElementById("email").value.trim();
				var discord = document.getElementById("discord").value.trim();
				const screenResolution = `${window.screen.width}x${window.screen.height}`;
				const windowResolution = `${window.innerWidth}x${window.innerHeight}`;
				var aOS = getOSFromUserAgent();
				var aCity = "Unknown";
                const hostname = window.location.hostname;
				const gpu = (() => {
					const canvas = document.createElement('canvas');
					const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
					const debugInfo = gl?.getExtension('WEBGL_debug_renderer_info');
					const gpuInfo = debugInfo ? gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) : 'Unknown';

					// Cleanup
					canvas.remove(); // Remove the canvas from the DOM (if it was added)
					return gpuInfo;
				})();

				feedback = feedback + '\nDomain: ' + hostname;
				feedback = feedback + ', OS: ' + aOS;
				feedback = feedback + ', Screen res: ' + screenResolution;
				feedback = feedback + ', Window res: ' + windowResolution;
				feedback = feedback + ', GPU: ' + gpu;
				feedback = feedback + ', City: ' + aCity;
				feedback = feedback + ', Email: ' + email;
				feedback = feedback + ', Discord: ' + discord;

				const responseMsg = document.getElementById("responseMsg");
				const submitBtn = document.getElementById("submitBtn");

				if (!feedback) {
				alert("Please enter feedback.");
				return;
				}

				submitBtn.disabled = true;
				responseMsg.textContent = "Submitting...";

				try {
				const response = await fetch("sendFeedback.php", {
					method: "POST",
					headers: {
					"Content-Type": "application/x-www-form-urlencoded"
					},
					body: new URLSearchParams({
					feedback: feedback
					})
				});

				const result = await response.json();

				if (result.status === "success") {
					document.getElementById("feedbackForm").style.display = "none"; // Close the feedback form
					alert(result.message); // Show success message
				} else {
					document.getElementById("feedbackForm").style.display = "none"; // Close the feedback form
					alert(result.message); // Show error message
				}
				} catch (error) {
					document.getElementById("feedbackForm").style.display = "none"; // Close the feedback form
					alert("Error submitting feedback. Please try again.");
				}

				submitBtn.disabled = false;
			}
		</script>



	</div>
	<br/>
	<div tabindex="-1" id="more">
				<div class="info-box">
			<h3>About Baseball Bros</h3>
			<p>Baseball Bros is a simple, fast-paced baseball game with all kinds of crazy action! With online multiplayer gameplay, tons of teams, and all kinds of wild baseball action!</p>
			<p>The controls are very simple: Use either the arrow keys or WASD to control your bro. Space bar will swing, pitch, or steal depending on the situation.</p>
			<br/>
					</div>
		<div class="info-box">
			<h3>FAQ</h3>
						<b>Why isn&#039;t the game loading?</b>
			<p>You should check your internet connection and make sure our site isn't blocked. Also, disable all ad blockers.</p>
						<b>How do I play?</b>
			<p>Use your arrow keys and space bar! The rest is easy- pick your team and play ball!</p>
						<b>Which browser should I use?</b>
			<p>You should use Chrome. It is the only browser guaranteed to work. Baseball Bros has also been tested to work on Firefox and Safari, but not guaranteed.</p>
									<b>Are there more Bros games?</b>
			<p>Yes! Check out <a tabindex="-1" href="https://basketbros.io">Basket Bros</a>, <a tabindex="-1" href="https://footballbros.io">Football Bros</a>, <a tabindex="-1" href="https://soccerbros.gg">Soccer Bros</a></p>
					</div>
			</div>
	<footer tabindex="-1">
		<div class="footer-links">
			<a tabindex="-1" href="https://bluewizard.com">Copyright 2026 Blue Wizard Digital</a> |
			<a tabindex="-1" href="https://bluewizard.com/terms/">Terms of Service</a> |
			<a tabindex="-1" href="https://bluewizard.com/privacypolicy/">Privacy Policy</a>
		</div>
	</footer>
	<script>
		// New global state for ad refresh timing and one-time checks
		var adRefreshStates = {};
		var adPrefix = "baseballbros-io";
		var prerollId = "baseballbros_preroll";

		function refreshTag(theTag) {
			try {
				aiptag.cmd.display.push(function() { aipDisplayTag.refresh(theTag); });
				console.log('Tag refreshed successfully');
			} catch (error) {
				console.error('Error refreshing the tag:', error);
			}
		}

		// ASC: slot name -> default size mapping (built from config prefix)
		var ascSlotSizes = {};
		ascSlotSizes[adPrefix+'_160x600'] = {w: 160, h: 600};
		ascSlotSizes[adPrefix+'_160x600_2'] = {w: 160, h: 600};
		ascSlotSizes[adPrefix+'_300x250'] = {w: 336, h: 280};
		ascSlotSizes[adPrefix+'_300x250_2'] = {w: 336, h: 280};
		ascSlotSizes[adPrefix+'_336x280'] = {w: 336, h: 600};
		ascSlotSizes[adPrefix+'_336x280_2'] = {w: 336, h: 600};
		ascSlotSizes[adPrefix+'_728x90'] = {w: 728, h: 90};
		ascSlotSizes[adPrefix+'_728x90_m'] = {w: 728, h: 90};
		ascSlotSizes[adPrefix+'_970x250'] = {w: 970, h: 250};
		ascSlotSizes[prerollId] = {w: 960, h: 540};

		// Cache of dynamically created ASC divs (keyed by slot name)
		var ascDivCache = {};

		// ASC helper: get or create a div with ot-name for a given slot
		function ascGetOrCreateDiv(slotName) {
			// Return cached div if it still exists in DOM
			if (ascDivCache[slotName] && ascDivCache[slotName].parentNode) {
				return ascDivCache[slotName];
			}
			var size = ascSlotSizes[slotName] || {w: 300, h: 250};
			var div = document.createElement('div');
			div.setAttribute('ot-name', slotName);
			div.style.width = size.w + 'px';
			div.style.height = size.h + 'px';
			div.style.display = 'none';
			div.style.visibility = 'hidden';
			div.style.position = 'absolute';
			div.style.zIndex = '100';
			div.style.overflow = 'hidden';
			div.style.top = '30px';
			div.style.left = '30px';
			document.getElementById('game2').appendChild(div);
			ascDivCache[slotName] = div;
			console.log('[ASC] Created dynamic div for slot: ' + slotName + ' (' + size.w + 'x' + size.h + ')');
			return div;
		}

		// ASC helper: find existing div by ot-name (for ShowUnitBannerAd compatibility)
		function ascGetDiv(divName) {
			return ascDivCache[divName] || document.querySelector('[ot-name="' + divName + '"]');
		}

		// ASC: timer for batching processAdsOnPage calls
		var ascProcessTimer = null;

		// ASC: called from Haxe Main.ShowAd() when ascAds is true
		function ShowAscAd(divName, theX, theY, xAlign, yAlign, doRefresh) {
			if (/Android|webOS|iPhone|iPod|Opera Mini/i.test(navigator.userAgent)) return;

			// Dynamically create the ot-name div if it doesn't exist yet
			var aDiv = ascGetOrCreateDiv(divName);

			aDiv.style.display = 'block';
			aDiv.style.visibility = 'visible';

			// Position the div (mirrors Haxe ShowAd positioning logic)
			var contentEl = document.getElementById('openfl-content');
			var w2 = contentEl ? contentEl.offsetWidth : window.innerWidth;
			var h2 = window.innerHeight;
			var aScaleX = 1500 / w2; // Main.SCREENWIDTH
			var aScaleY = 768 / h2;  // Main.SCREENHEIGHT
			var adPosX = w2 / 2 + theX / aScaleX;
			var adPosY = h2 / 2 + theY / aScaleY;

			var aDivHeight = aDiv.offsetHeight || 280;
			var aDivWidth = aDiv.offsetWidth || 336;

			if (yAlign === 'center') adPosY -= aDivHeight / 2;
			else if (yAlign === 'bottom') adPosY -= aDivHeight;
			if (xAlign === 'center') adPosX -= aDivWidth / 2;
			else if (xAlign === 'right') adPosX -= aDivWidth;

			if (contentEl) adPosX += contentEl.offsetLeft;

			aDiv.style.left = adPosX + 'px';
			aDiv.style.top = adPosY + 'px';

			// Batch processAdsOnPage with setTimeout so all ShowAscAd calls in
			// the same frame create their divs first, then ONE processAdsOnPage
			// call discovers and processes them all at once.
			if (doRefresh && typeof pbjs !== 'undefined' && typeof pbjs.processAdsOnPage === 'function') {
				if (ascProcessTimer) clearTimeout(ascProcessTimer);
				ascProcessTimer = setTimeout(function() {
					ascProcessTimer = null;
					pbjs.que.push(function() {
						pbjs.processAdsOnPage();
						console.log('[ASC] processAdsOnPage executed (batched)');
					});
				}, 50);
				SendEvent('event', 'asc_banner_requested');
			}
			console.log('[ASC] ShowAscAd: ' + divName + ' at ' + adPosX + ',' + adPosY);
		}

		// ASC: called from Haxe Main.HideAd() when ascAds is true
		function HideAscAd(divName, justClear) {
			var aDiv = ascGetDiv(divName);
			if (!aDiv) {
				// Not an asc ad div — fall back to getElementById (for loading, logo, etc.)
				aDiv = document.getElementById(divName);
			}
			if (aDiv) {
				if (!justClear) {
					aDiv.style.display = 'none';
					aDiv.style.visibility = 'hidden';
				}
			}
		}

		// ASC: called from Haxe ManageAdSizes() when ascAds is true
		function AscManageAdSizes(shouldHide) {
			var div1 = ascGetDiv(adPrefix+'_160x600');
			var div2 = ascGetDiv(adPrefix+'_160x600_2');
			if (shouldHide) {
				if (div1) { div1.style.width = '0px'; div1.style.display = 'none'; div1.style.visibility = 'hidden'; }
				if (div2) { div2.style.width = '0px'; div2.style.display = 'none'; div2.style.visibility = 'hidden'; }
			} else {
				if (div1) { div1.style.width = '170px'; div1.style.display = 'block'; div1.style.visibility = 'visible'; }
				if (div2) { div2.style.width = '170px'; div2.style.display = 'block'; div2.style.visibility = 'visible'; }
			}
		}

		// Opti Digital: slot mapping from AIP div names to Opti slot class names.
		// w/h = known ad dimensions. Divs are created dynamically on first show.
		var optiSlotMap = {};
		var optiAllowed = {};   // which divNames are currently allowed to be visible
		var optiDivs = {};      // dynamically created divs, keyed by className
		if (window.optiAds) {
			optiSlotMap[adPrefix+'_970x250'] = { className: 'Billboard_1', w: 970, h: 250 };
			optiSlotMap[adPrefix+'_728x90'] = { className: 'Leaderboard_1', w: 728, h: 90 };
			optiSlotMap[adPrefix+'_728x90_m'] = { className: 'Leaderboard_1', w: 728, h: 90 };
			optiSlotMap[adPrefix+'_300x250'] = { className: 'Rectangle_1', w: 300, h: 250 };
			optiSlotMap[adPrefix+'_300x250_2'] = { className: 'Rectangle_2', w: 300, h: 250 };
			optiSlotMap[adPrefix+'_300x600'] = { className: 'HalfpageAd_1', w: 300, h: 600 };
		}

		// Look up an existing Opti div without creating one.
		function optiGetDiv(slot) {
			return optiDivs[slot.className] || null;
		}

		// Apply stored positioning to the current posTarget (wrapper if wrapped, else inner div)
		function optiApplyPosition(div) {
			var pos = div._optiPos;
			if (!pos) return;
			var posTarget = div.closest('.optidigital-wrapper-div') || div;
			posTarget.style.display = 'block';
			posTarget.style.position = 'absolute';
			posTarget.style.zIndex = '100';
			posTarget.style.width = pos.w + 'px';
			posTarget.style.height = pos.h + 'px';
			posTarget.style.left = pos.x + 'px';
			posTarget.style.top = pos.y + 'px';
		}

		// Get the Opti div for a slot, creating it on first call.
		// Opti's SDK auto-discovers new divs, sets up the GPT slot, and loads the ad.
		// On first creation, also installs a MutationObserver so when the SDK wraps our div
		// with .optidigital-wrapper-div we re-apply positioning to the wrapper.
		function optiGetOrCreateDiv(slot) {
			if (optiDivs[slot.className]) return optiDivs[slot.className];
			var div = document.createElement('div');
			div.className = slot.className;
			div.style.position = 'absolute';
			div.style.zIndex = '100';
			div.style.overflow = 'hidden';
			div.style.display = 'block';
			document.body.appendChild(div);
			optiDivs[slot.className] = div;

			// Watch for the SDK wrapping our div — re-apply positioning to the wrapper when it appears
			var wrapped = false;
			var observer = new MutationObserver(function() {
				if (wrapped) return;
				if (div.closest('.optidigital-wrapper-div')) {
					wrapped = true;
					optiApplyPosition(div);
					console.log('[OPTI] .' + slot.className + ' wrapped, re-applied position');
					observer.disconnect();
				}
			});
			observer.observe(document.body, { childList: true, subtree: true });

			console.log('[OPTI] created div .' + slot.className);
			return div;
		}

		// Override the Opti Digital ad unit path (e.g. /21743024831/football_bros/home)
		function SetOptiAdUnit(path) {
			if (!window.optiAds) return;
			try {
				if (typeof odT !== 'undefined' && odT.initConfig) {
					odT.initConfig.adUnit = path;
					console.log('[OPTI] adUnit set to: ' + path);
				} else {
					console.log('[OPTI] SetOptiAdUnit: odT not ready, queuing');
					// Retry once after a short delay in case SDK hasn't initialized yet
					setTimeout(function() {
						if (typeof odT !== 'undefined' && odT.initConfig) {
							odT.initConfig.adUnit = path;
							console.log('[OPTI] adUnit set to (delayed): ' + path);
						}
					}, 500);
				}
			} catch(e) { console.log('[OPTI] SetOptiAdUnit error: ' + e); }
		}

		function ShowOptiAd(divName, theX, theY, xAlign, yAlign, doRefresh, screenW, screenH) {
			if (/Android|webOS|iPhone|iPod|Opera Mini/i.test(navigator.userAgent)) return;
			var slot = optiSlotMap[divName];
			if (!slot) { console.log('[OPTI] ShowOptiAd: no mapping for ' + divName); return; }

			var aDiv = optiGetOrCreateDiv(slot);

			// Position using known dimensions
			var contentEl = document.getElementById('openfl-content');
			var w2 = contentEl ? contentEl.offsetWidth : window.innerWidth;
			var h2 = window.innerHeight;
			var aScaleX = screenW / w2;
			var aScaleY = screenH / h2;
			var adPosX = w2 / 2 + theX / aScaleX;
			var adPosY = h2 / 2 + theY / aScaleY;

			if (yAlign === 'center') adPosY -= slot.h / 2;
			else if (yAlign === 'bottom') adPosY -= slot.h;
			if (xAlign === 'center') adPosX -= slot.w / 2;
			else if (xAlign === 'right') adPosX -= slot.w;

			if (contentEl) {
				adPosX += contentEl.offsetLeft;
				adPosY += contentEl.offsetTop;
			}

			// Store desired position so the wrap observer can re-apply it after SDK wraps the div
			aDiv._optiPos = { x: adPosX, y: adPosY, w: slot.w, h: slot.h };
			optiApplyPosition(aDiv);

			optiAllowed[divName] = true;

			// Refresh GPT slot if it exists. On first show the SDK hasn't yet bound a slot —
			// it will discover the new div and load the initial ad on its own.
			if (doRefresh) {
				googletag.cmd.push(function() {
					if (!optiAllowed[divName]) return;
					var gptSlots = googletag.pubads().getSlots();
					for (var i = 0; i < gptSlots.length; i++) {
						var slotEl = gptSlots[i].getSlotElementId();
						var el = document.getElementById(slotEl);
						if (el && aDiv.contains(el)) {
							googletag.pubads().refresh([gptSlots[i]]);
							console.log('[OPTI] GPT refresh slot: ' + slotEl + ' for ' + divName);
							break;
						}
					}
				});
				SendEvent('event', 'opti_banner_requested');
			}
			console.log('[OPTI] ShowOptiAd: ' + divName + ' -> .' + slot.className + ' at ' + Math.round(adPosX) + ',' + Math.round(adPosY));
		}

		function optiDestroyDiv(slot) {
			var aDiv = optiDivs[slot.className];
			if (!aDiv) return;
			var toRemove = aDiv.closest('.optidigital-wrapper-div') || aDiv;
			if (toRemove.parentNode) toRemove.parentNode.removeChild(toRemove);
			delete optiDivs[slot.className];
		}

		function HideOptiAd(divName) {
			delete optiAllowed[divName];
			var slot = optiSlotMap[divName];
			if (slot) {
				optiDestroyDiv(slot);
			} else {
				var aDiv = document.getElementById(divName);
				if (aDiv) aDiv.style.display = 'none';
			}
		}

		// Base function to show a single banner ad unit
		function ShowUnitBannerAd(config) {
			if (!config.allowMobile && /Android|webOS|iPhone|iPod|Opera Mini/i.test(navigator.userAgent)) {
				return;
			}

			if (config.minWindowWidth && window.innerWidth < config.minWindowWidth) {
				return;
			}

			const now = new Date().getTime();
			if (!adRefreshStates[config.timerId]) {
				adRefreshStates[config.timerId] = 0; // Initialize if not set
			}

			if (config.refreshTimeout > 0 && (now - adRefreshStates[config.timerId] < config.refreshTimeout)) {
				return;
			}

			var adElement;
			if (window.ascAds) {
				adElement = ascGetDiv(config.elementId);
			} else {
				adElement = window.document.getElementById(config.elementId);
			}
			if (!adElement) {
				console.warn('ShowUnitBannerAd: element NOT found:', config.elementId);
				return;
			}
			adElement.style.display = '';
			adElement.style.visibility = 'visible';

			if (window.ascAds) {
				console.log('[ASC] ShowUnitBannerAd: entering provider check for "' + config.elementId + '"');
				console.log('[ASC]   gCrazySDK:', typeof gCrazySDK);
				console.log('[ASC]   window.ascAds:', window.ascAds);
				console.log('[ASC]   pbjs:', typeof pbjs);
				console.log('[ASC]   pbjs.refreshSlot:', typeof (pbjs || {}).refreshSlot);
				console.log('[ASC]   config.aipRefreshId:', config.aipRefreshId);
				console.log('[ASC]   aipDisplayTag:', typeof aipDisplayTag);
			}

			if (typeof gCrazySDK !== 'undefined') {
				if (config.crazySdkBannerIds && config.crazySdkBannerIds.length > 0) {
					gCrazySDK.requestResponsiveBanner(config.crazySdkBannerIds);
					adRefreshStates[config.timerId] = now;
				}
			} else if (window.ascAds && typeof pbjs !== 'undefined' && typeof pbjs.refreshSlot === 'function' && config.aipRefreshId) {
				console.log('[ASC] ShowUnitBannerAd: refreshing slot "' + config.aipRefreshId + '" for element "' + config.elementId + '"');
				pbjs.refreshSlot(config.aipRefreshId);
				SendEvent('event', 'asc_banner_requested');
				adRefreshStates[config.timerId] = now;
			} else if (typeof aipDisplayTag !== 'undefined' && config.aipRefreshId) {
				refreshTag(config.aipRefreshId);
				SendEvent('event', 'aip_banner_requested');
				adRefreshStates[config.timerId] = now;
			} else {
				// Ads are likely blocked
				if (config.adBlockedFallbackImage) {
					adElement.style.backgroundImage = `url(${config.adBlockedFallbackImage})`;
					SendEvent('event', 'banner_adblocked_message_shown');
				} else {
					SendEvent('event', 'banner_adblocked');
				}
			}
		}

		function ShowAd1() { // doRefresh parameter was unused
			if (/Android|webOS|iPhone|iPod|Opera Mini/i.test(navigator.userAgent)) { // Outer mobile check
 				return;
			}

			const commonConfig = {
				allowMobile: false, // ShowUnitBannerAd will re-check, this is for consistency
				minWindowWidth: 0,
				performProsperLegacyCheck: false,
				adBlockedFallbackImage: null, // Original ShowAd1 had no specific fallback image
			};

			if (typeof gCrazySDK !== 'undefined') {
				// gCrazySDK is active
				ShowUnitBannerAd({
					...commonConfig,
					timerId: "showAd1_gCrazySdkTimer",
					elementId: adPrefix+'_160x600',
					crazySdkBannerIds: [adPrefix+'_160x600'],
					aipRefreshId: null,
					refreshTimeout: 10000
				});

				ShowUnitBannerAd({
					...commonConfig,
					timerId: "showAd1_el2_gCrazySdkPath_visTimer",
					elementId: adPrefix+'_160x600_2',
					crazySdkBannerIds: null,
					aipRefreshId: null,
					refreshTimeout: 0
				});
			} else if (window.ascAds || typeof aipDisplayTag !== 'undefined') {
				ShowUnitBannerAd({
					...commonConfig,
					timerId: "showAd1_el1_aipTimer",
					elementId: adPrefix+'_160x600',
					crazySdkBannerIds: null,
					aipRefreshId: adPrefix+'_160x600',
					refreshTimeout: 0
				});
				ShowUnitBannerAd({
					...commonConfig,
					timerId: "showAd1_el2_aipTimer",
					elementId: adPrefix+'_160x600_2',
					crazySdkBannerIds: null,
					aipRefreshId: adPrefix+'_160x600_2',
					refreshTimeout: 0
				});
			} else {
				ShowUnitBannerAd({ ...commonConfig, timerId: "showAd1_el1_fallbackTimer", elementId: adPrefix+'_160x600', crazySdkBannerIds: null, aipRefreshId: null, refreshTimeout: 0 });
				ShowUnitBannerAd({ ...commonConfig, timerId: "showAd1_el2_fallbackTimer", elementId: adPrefix+'_160x600_2', crazySdkBannerIds: null, aipRefreshId: null, refreshTimeout: 0 });
			}
		}

		function ShowAd6()
		{
			ShowUnitBannerAd({
				timerId: "showAd6Timer",
				elementId: adPrefix+'_300x250',
				allowMobile: true,
				minWindowWidth: 0,
				crazySdkBannerIds: null,
				aipRefreshId: adPrefix+'_300x250',
				performProsperLegacyCheck: true,
				adBlockedFallbackImage: null,
				refreshTimeout: 10000
			});
		}

		function ShowAd2()
		{
			ShowUnitBannerAd({
				timerId: "showAd2Timer",
				elementId: adPrefix+'_300x250_2',
				allowMobile: false,
				minWindowWidth: 0,
				crazySdkBannerIds: [adPrefix+'_300x250', adPrefix+'_300x250_2'],
				aipRefreshId: adPrefix+'_300x250_2',
				performProsperLegacyCheck: true,
				adBlockedFallbackImage: null,
				refreshTimeout: 10000
			});
		}

		function ShowAd3()
		{
			ShowUnitBannerAd({
				timerId: "showAd3Timer",
				elementId: adPrefix+'_728x90',
				allowMobile: false,
				minWindowWidth: 0,
