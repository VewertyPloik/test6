			}

			//aiptag.settings.iDisableAutoRefreshAfterDestroy = true;
			aiptag.cmd.player.push(function() {
				adplayer = new aipPlayer({
					AIP_ADBREAK_COMPLETE: function ()  {
						console.log("Adbreak Completed");
						Main.DoneInterstitialAd(false);
					},
					AD_WIDTH: 960,
					AD_HEIGHT: 540,
					AD_DISPLAY: 'default', //default, fullscreen, center, fill
					TRUSTED: true,
					LOADING_TEXT: 'loading advertisement',
					PREROLL_ELEM: function(){return document.getElementById('preroll')},
					AIP_COMPLETE: function (state)  {
						/*******************
						 ***** WARNING *****
						*******************
						Please do not remove the PREROLL_ELEM
						from the page, it will be hidden automaticly.
						If you do want to remove it use the AIP_REMOVE callback.
						*/
						Main.DoneVideoAd();
						window.focus();
						window.document.getElementById('openfl-content').focus();
						if(state == null) state = 'null';
						console.log('Video Ad Complete: '+state);
						SendEvent('event', 'donevideo-'+lastUnitPlayed+"-"+state);
					},
					AIP_REMOVE: function ()  {
						// Here it's safe to remove the PREROLL_ELEM from the page if you want. But it's not recommend.
					}
				});
			});

		</script>
				<script async src="//api.adinplay.com/libs/aiptag/pub/SSK/baseballbros.io/tag.min.js"></script>
			
	<script>

		

	function SetupMSNotification()
	{
		console.log("notifying");
		if(typeof $msstart !== 'undefined')
		{
			console.log("notifying2");
			var id = btoa("https:\/\/baseballbros.io\/sbros_364x180.png");
			$msstart.scheduleNotificationAsync({title: "Unlock new bros now!",
												description: "You are just about to unlock a new Bro! Who will it be?",
												type: 1,
												minDelayInSeconds: 24*60*60
											}).then(response => {
					console.log("notification response: "+response);
				});
			$msstart.scheduleNotificationAsync({title: "Hit nukes all over your bros!",
											description: "New bros just waiting to be struck out! Unlock them now!",
											type: 1,
											minDelayInSeconds: 24*7*60*60
										}).then(response => {
				console.log("notification response: "+response);
			});

  		}
	}

	var msAdID;
	function LoadVideo()
	{
		if(typeof $msstart !== 'undefined')
		{
			$msstart.loadAdsAsync().then(adInstance => {
    			// Use the adInstance.instanceId to make a call to showAdsAsync
				msAdID = adInstance.instanceId;
			});

			SetupMSNotification();
		}
	}

	function ShowVideo(theUnitName=null)
	{
		//Main.DoneVideoAd(true);
		//return;//! when aip is live, remove this

		console.log('SHOW_VIDEO:'+theUnitName);
		var aUnitName = "";
		if(typeof $msstart !== 'undefined')
		{
			$msstart.showAdsAsync(msAdID).then(adInstance => {
   			 	// Use the adInstance.showAdsCompletedAsync to be notified of the completion of showing the advertisement
				adInstance.showAdsCompletedAsync.then((val) => {
					console.log('MS Video Ad Complete');
					Main.DoneVideoAd();
					window.focus();
					window.document.getElementById('openfl-content').focus();
					LoadVideo();
				}).catch((err) => {
					console.log('Ms Video Ad Error');
					Main.DoneVideoAd();
					window.focus();
					window.document.getElementById('openfl-content').focus();
					LoadVideo();
				});
			});
		}
		else if(typeof gCrazySDK !== 'undefined') {
			gCrazySDK.addEventListener("adFinished", Main.DoneVideoAd); // reenable sound, enable ui
			gCrazySDK.addEventListener("adError", Main.DoneVideoAd); // reenable sound, enable ui
			gCrazySDK.requestAd();
			console.log('CG_AD_REQUESTED');
			SendEvent('event', 'cgvideo');
			return;
		}
		else if (window.ascAds) {
			console.log('[ASC] ShowVideo: ascAds=true, attempting preroll');
			// Dynamically create preroll div on demand
			var prerollDiv = ascGetOrCreateDiv("baseballbros_preroll");
			prerollDiv.style.display = 'block';
			prerollDiv.style.visibility = 'visible';
			prerollDiv.style.position = 'fixed';
			prerollDiv.style.top = '50%';
			prerollDiv.style.left = '50%';
			prerollDiv.style.transform = 'translate(-50%, -50%)';
			prerollDiv.style.zIndex = '150';
			if (typeof pbjs !== 'undefined' && typeof pbjs.processAdsOnPage === 'function') {
				lastUnitPlayed = 'asc_preroll';
				SendEvent('event', 'startvideo-asc_preroll');
				console.log('[ASC] ShowVideo: calling processAdsOnPage for preroll');
				pbjs.que.push(function() { pbjs.processAdsOnPage(); });

				// Create skip button as a SEPARATE fixed element on body
				// (processAdsOnPage replaces ad div contents, destroying any children)
				var skipBtn = document.createElement('div');
				skipBtn.id = 'asc-preroll-skip';
				skipBtn.style.cssText = 'position:fixed; bottom:calc(50% - 250px); right:calc(50% - 460px); z-index:200; background:rgba(0,0,0,0.7); color:#fff; padding:8px 16px; font-family:sans-serif; font-size:14px; border-radius:4px; cursor:default; user-select:none;';
				document.body.appendChild(skipBtn);

				var countdown = 5;
				skipBtn.textContent = 'Skip in ' + countdown + '...';
				var countdownInterval = setInterval(function() {
					countdown--;
					if (countdown > 0) {
						skipBtn.textContent = 'Skip in ' + countdown + '...';
					} else {
						clearInterval(countdownInterval);
						skipBtn.textContent = 'Skip Ad \u25B6';
						skipBtn.style.cursor = 'pointer';
						skipBtn.style.background = 'rgba(0,0,0,0.85)';
						skipBtn.onmouseover = function() { skipBtn.style.background = 'rgba(50,50,50,0.95)'; };
						skipBtn.onmouseout = function() { skipBtn.style.background = 'rgba(0,0,0,0.85)'; };
						skipBtn.onclick = function() {
							clearInterval(countdownInterval);
							prerollDiv.style.display = 'none';
							prerollDiv.style.visibility = 'hidden';
							if (skipBtn.parentNode) skipBtn.parentNode.removeChild(skipBtn);
							Main.DoneVideoAd();
							window.focus();
							window.document.getElementById('openfl-content').focus();
							console.log('[ASC] ShowVideo: preroll skipped by user');
						};
					}
				}, 1000);
			} else {
				console.warn('[ASC] ShowVideo: pbjs.processAdsOnPage not available, skipping preroll');
				Main.DoneVideoAd();
				window.focus();
				window.document.getElementById('openfl-content').focus();
			}
		}
		else if (window.optiAds) {
			console.log('[OPTI] ShowVideo: no video ad support, completing immediately');
			Main.DoneVideoAd();
			window.focus();
			window.document.getElementById('openfl-content').focus();
		}
		else if (typeof adplayer === 'undefined') {
			Main.DoneVideoAd(true);
			SendEvent('event', 'video_adblocked');
			console.log('VIDEO_ADBLOCKED');

		} else {
			var aStr = 'preroll';
			//if(theUnitName != null) aStr = theUnitName;
			lastUnitPlayed = aStr;
			SendEvent('event', 'startvideo-'+aStr);

			aiptag.cmd.player.push(function() { adplayer.startVideoAd(theUnitName); });
		}
	}
	</script>

	<!-- Firebase App (the core Firebase SDK) -->
	<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
	<!-- Firebase Authentication -->
	<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-auth.js"></script>
	<!-- Firebase Firestore (Database) -->
	<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-firestore.js"></script>

	<script>
		// Your web app's Firebase configuration
  		const firebaseConfig = {
			apiKey: "AIzaSyBuzj8XEP7-5kOFFhyuxylQ6P0B2G_ogsM",
			authDomain: "baseball-bros-8dd7f.firebaseapp.com",
			projectId: "baseball-bros-8dd7f",
			storageBucket: "baseball-bros-8dd7f.firebasestorage.app",
			messagingSenderId: "618024516218",
			appId: "1:618024516218:web:11efff2d4b092aefaf99c3"  		};

		// Initialize Firebase
		firebase.initializeApp(firebaseConfig);
		const auth = firebase.auth();
		const db = firebase.firestore();
		var userData = "";

		function triggerSignIn()
		{
			var provider = new firebase.auth.GoogleAuthProvider();
			auth.signInWithPopup(provider);
		}

				// Save game data function
		function saveGameData(gameDataValue) {
			console.log('saving gameData:' + gameDataValue);
			var userId = auth.currentUser.uid;
			userData = gameDataValue;
			db.collection('users').doc(userId).set({
				gameData: gameDataValue
			}).then(function() {
				console.log('Game data saved');
			}).catch(function(error) {
				console.error('Error saving game data:', error);
			});
		}

		// Load game data function
		function loadGameData() { return userData; }

		function loadGameDataAsync() {
			var userId = auth.currentUser.uid;
			db.collection('users').doc(userId).get().then(function(doc) {
				if (doc.exists) {
					userData = doc.data().gameData;
					//Main.LoadGlobals();
					console.log('Game data:', doc.data().gameData);
					if (typeof Main != "undefined")
					{
						Main.LoadDataComplete();
					}
				// Use the game data in your game
				} else {
				console.log('No such document!');
				}
			}).catch(function(error) {
				console.error('Error loading game data:', error);
			});
		}

   // Firebase auth state observer
   		auth.onAuthStateChanged(function(user) {
      		if (user) {
				loadGameDataAsync();
				SendEvent('event', 'sign_in');
				console.log('user signed in');
			} else {
				console.log('No user signed in');
				SendEvent('event', 'sign_out');
			}
    	});

		function signOut()
		{
			auth.signOut().then(() => {
				Main.SignOutComplete();
				console.log('signed out');
			});
		}

		function isUserLoggedIn() {
			return auth.currentUser !== null;
		}
	</script>

	
</head>
