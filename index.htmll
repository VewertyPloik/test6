		function EmailSignup() {
			if(document.getElementById("signup") || document.getElementById("deleteme")) return;
			const iframe = document.createElement("iframe");
			iframe.src = "https://bluewizard.com/subscribe-to-bbros/";

//			iframe.style.display = "block";
			iframe.style.width = "550px";
			iframe.style.height = ""+window.innerHeight-100+"px";
			iframe.style.position = "absolute";
			iframe.style.top = "50px";
			iframe.style.left = "50%";
			iframe.style["margin-left"] = "-225px";
			//iframe.style["margin-right"] = "-275px";
			iframe.style["max-width"] = "100%";
			iframe.setAttribute("id", "signup");

			document.body.appendChild(iframe);
		}

		function HideAllAds(hideSides)
		{
			console.log("HideAllAds");

			// Explicitly hide all ad unit divs
			HideAd(adPrefix+'_300x250');
			HideAd(adPrefix+'_300x250_2');
			HideAd(adPrefix+'_336x280');
			HideAd(adPrefix+'_336x280_2');
			HideAd(adPrefix+'_728x90');
			HideAd(adPrefix+'_728x90_m');
			HideAd(adPrefix+'_970x250');
			HideAd(adPrefix+'_160x600');
			HideAd(adPrefix+'_160x600_2');
			HideAd(adPrefix+'_300x600');

			if(typeof $msstart !== 'undefined')
			{
				$msstart.hideDisplayAdsAsync().then(response => {
					// Returns string indicating success if ad was hidden successfully
				});
				console.log("MS ads destroyed");
			}
			if(typeof gCrazySDK !== 'undefined') {
				gCrazySDK.clearAllBanners();
				console.log("CG ads destroyed");
			}
			if(typeof aipDisplayTag !== 'undefined') {
				aipDisplayTag.destroy();
				console.log("AIP ads destroyed");
			}
			if(window.ascAds) {
				console.log('[ASC] HideAllAds: destroying all slots and removing dynamic divs');
				if (typeof pbjs !== 'undefined' && typeof pbjs.destroyAllSlots === 'function') {
					pbjs.destroyAllSlots();
					console.log('[ASC] HideAllAds: destroyAllSlots() called');
				}
				// Remove all dynamically created asc divs from DOM and clear cache
				// so they get recreated fresh on next ShowAscAd
				for (var slotName in ascDivCache) {
					if (ascDivCache[slotName] && ascDivCache[slotName].parentNode) {
						ascDivCache[slotName].parentNode.removeChild(ascDivCache[slotName]);
					}
				}
				ascDivCache = {};
			}
			if(window.optiAds) {
				optiAllowed = {};
				for (var key in optiDivs) {
					var d = optiDivs[key];
					if (d) {
						var toRemove = d.closest('.optidigital-wrapper-div') || d;
						if (toRemove.parentNode) toRemove.parentNode.removeChild(toRemove);
					}
				}
				optiDivs = {};
				console.log('[OPTI] HideAllAds');
			}
			//killAdSubframes();

		}

		function HideAd(divName, justClear) {
			if (justClear === undefined) justClear = false;
			if (window.optiAds) { HideOptiAd(divName); return; }
			if (window.ascAds) { HideAscAd(divName, justClear); return; }
			var aDiv = document.getElementById(divName);
			if (aDiv != null) {
				if (!justClear) {
					aDiv.style.display = "none";
					aDiv.style.visibility = "hidden";
				}
				aDiv.innerHTML = " ";
			}
		}

		// Kill ad-spawned iframes (viewability trackers, verification scripts, etc.)
		// that ad SDKs append to document.body outside of the ad container divs.
		// The game iframe is preserved. The parent-page adinplay SDK stays warm.
		var gameIframeRef = null;
		function killAdSubframes() {
			if (!gameIframeRef) {
				gameIframeRef = document.querySelector('#openfl-content iframe');
			}
			var iframes = document.querySelectorAll('iframe');
			for (var i = iframes.length - 1; i >= 0; i--) {
				var f = iframes[i];
				// Keep the game iframe and the GTM noscript iframe
				if (f === gameIframeRef) continue;
				if (f.parentNode && f.parentNode.tagName === 'NOSCRIPT') continue;
				// Kill it
				f.src = 'about:blank';
				if (f.parentNode) f.parentNode.removeChild(f);
			}
		}

		function ShowAdPosition(divName, theX, theY, xAlign, yAlign, doRefresh, screenW, screenH) {
			if (window.optiAds) { ShowOptiAd(divName, theX, theY, xAlign, yAlign, doRefresh, screenW, screenH); return; }
			if (window.ascAds) { ShowAscAd(divName, theX, theY, xAlign, yAlign, doRefresh); return; }
			var aDiv = document.getElementById(divName);
			if (aDiv == null) return;

			aDiv.style.display = "block";
			aDiv.style.visibility = "visible";

			if (doRefresh) {
				switch (divName) {
					case adPrefix+'_160x600':
						var aDiv2 = document.getElementById(divName + "_2");
						if (aDiv2) { aDiv2.style.display = "block"; aDiv2.style.visibility = "visible"; }
						ShowAd1(); return;
					case adPrefix+'_300x250': ShowAd6(); break;
					case adPrefix+'_300x250_2': ShowAd2(); break;
					case adPrefix+'_728x90': ShowAd3(); break;
					case adPrefix+'_336x280': ShowAd4(); break;
					case adPrefix+'_336x280_2': ShowAd7(); break;
					case adPrefix+'_728x90_m': ShowAd8(); break;
					case adPrefix+'_970x250': ShowAd9(); break;
					case adPrefix+'_300x600': ShowAd10(); break;
				}
			}

			var contentDiv = document.getElementById("openfl-content");
			var w2 = contentDiv.offsetWidth;
			var h2 = window.innerHeight;
			var aScaleX = screenW / w2;
			var aScaleY = screenH / h2;
			var adPosX = w2 / 2 + theX / aScaleX;
			var adPosY = h2 / 2 + theY / aScaleY;
			var aDivHeight = aDiv.offsetHeight; if (aDivHeight <= 0) aDivHeight = 280;
			var aDivWidth = aDiv.offsetWidth; if (aDivWidth <= 0) aDivWidth = 336;
			if (yAlign == "center") adPosY -= aDivHeight / 2;
			else if (yAlign == "bottom") adPosY -= aDivHeight;
			if (xAlign == "center") adPosX -= aDivWidth / 2;
			else if (xAlign == "right") adPosX -= aDivWidth;
			adPosX += contentDiv.offsetLeft;
			aDiv.style.left = adPosX + "px";
			aDiv.style.top = adPosY + "px";
		}

		function GamePlayStart() {
			if(typeof gCrazySDK !== 'undefined')
			{
				console.log("GamePlayStart");
				gCrazySDK.gameplayStart();
